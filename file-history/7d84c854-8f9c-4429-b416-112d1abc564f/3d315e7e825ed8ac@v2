    "allow": [
      "PowerShell(gh auth status 2>&1)",
      "PowerShell(node --version)",
      "PowerShell(npm --version)",
      "PowerShell(*node generate.mjs*)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "PowerShell(Get-ChildItem \"$env:USERPROFILE\\\\.claude\" -ErrorAction SilentlyContinue | Select-Object Name, PSIsContainer)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "PowerShell(Get-ChildItem \"$env:USERPROFILE\\\\.claude\\\\skills\" -ErrorAction SilentlyContinue | Select-Object Name, PSIsContainer)",
      "PowerShell(Remove-Item \"$env:TEMP\\\\anthropics-skills\" -Recurse -Force)",
      "WebFetch(domain:github.com)",
      "Bash(curl -s \"https://api.github.com/repos/DavidROliverBA/Daves-Claude-Code-Skills\")",
      "Bash(curl -s \"https://api.github.com/repos/DavidROliverBA/Daves-Claude-Code-Skills/commits?per_page=10\")",
      "PowerShell(if \\(Test-Path \"$env:USERPROFILE\\\\.claude\\\\skills\"\\) { Get-ChildItem -Path \"$env:USERPROFILE\\\\.claude\\\\skills\" -Recurse -File | Select-Object -ExpandProperty Name } else { \"No .claude/skills directory found\" })",
      "WebFetch(domain:medium.com)",
      "PowerShell(git clone https://github.com/DavidROliverBA/Daves-Claude-Code-Skills.git \"$env:TEMP\\\\daves-skills\" 2>&1)",
      "PowerShell(Get-ChildItem \"$env:TEMP\\\\daves-skills\" | Select-Object Name, PSIsContainer)",
      "PowerShell(Remove-Item \"$env:TEMP\\\\daves-skills\" -Recurse -Force)",
      "WebFetch(domain:api.github.com)",
      "Bash(cd /c/Users/yaniv/.claude/skills && wc -l *.md | tail -1)",
      "Read(//c/c/Users/yaniv/.claude/**)",
      "Bash(python3)",
      "Bash(curl -s \"https://raw.githubusercontent.com/anthropics/skills/main/skills/internal-comms/SKILL.md\")",
      "Read(//tmp/**)",
      "Bash(gws gmail *)",
      "Bash(npm show *)",
      "Bash(npx skills *)",
      "Skill(code-review)",
      "Skill(code-review:*)",
      "Bash(git diff *)",
      "Skill(schedule)",
      "Skill(schedule:*)",
      "PowerShell(npx skills add unicodeveloper/shannon 2>&1)",
      "PowerShell(git -C \"c:\\\\Users\\\\yaniv\\\\ליו\" remote -v 2>&1)",
      "PowerShell(winget list GitHub.cli 2>&1)",
      "PowerShell(winget install --id GitHub.cli --silent --accept-package-agreements --accept-source-agreements 2>&1)",
      "PowerShell($env:PATH = $env:PATH + \";C:\\\\Program Files\\\\GitHub CLI\"; gh --version 2>&1)",
      "PowerShell($env:PATH = $env:PATH + \";C:\\\\Program Files\\\\GitHub CLI\"; gh auth status 2>&1)",
      "PowerShell($env:PATH = [System.Environment]::GetEnvironmentVariable\\(\"PATH\",\"Machine\"\\) + \";\" + [System.Environment]::GetEnvironmentVariable\\(\"PATH\",\"User\"\\); gh auth status 2>&1)",
      "PowerShell(\\(Get-Command gh -ErrorAction SilentlyContinue\\).Source)",
      "PowerShell(Get-Item \"C:\\\\Program Files\\\\GitHub CLI\\\\gh.exe\" -ErrorAction SilentlyContinue | Select-Object FullName; Test-Path \"$env:APPDATA\\\\GitHub CLI\\\\hosts.yml\")",
      "Bash(Get-Content \"C:\\\\Users\\\\yaniv\\\\.claude\\\\settings.json\" -ErrorAction SilentlyContinue)",
      "Bash(Get-ChildItem \"C:\\\\Users\\\\yaniv\\\\.antigravity-ide\\\\\" -ErrorAction SilentlyContinue | Select-Object Name, FullName)"
    ],
    "additionalDirectories": [
      "C:\\Users\\yaniv"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "if ((Test-Path '.git') -and -not (Test-Path '.claude\\settings.json')) { $base = \"$env:USERPROFILE\\.claude\\templates\\project\"; New-Item -ItemType Directory -Force '.claude' | Out-Null; Copy-Item \"$base\\.claude\\settings.json\" '.claude\\settings.json' -Force; if (Test-Path \"$base\\.mcp.json\") { Copy-Item \"$base\\.mcp.json\" '.mcp.json' -Force }; Write-Output '{\"systemMessage\": \"📋 הוגדר מה-template: settings.json + .mcp.json — פרויקט חדש זוהה\"}' }",
            "shell": "powershell"
          },
          {
            "type": "command",
            "command": "if (Test-Path 'package.json' -and -not (Test-Path 'node_modules')) { Write-Output '{\"systemMessage\": \"⚠️ שים לב: קובץ package.json קיים אך תיקיית node_modules חסרה. מומלץ להריץ npm install\"}' }; if (Test-Path '.env.example' -and -not (Test-Path '.env')) { Write-Output '{\"systemMessage\": \"🔑 שים לב: קובץ .env חסר אך קיים .env.example. כדאי להעתיק וליצור קובץ הגדרות מקומי.\"}' }",
            "shell": "powershell"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python -c \"import winsound; winsound.PlaySound(r'C:\\\\Windows\\\\Media\\\\tada.wav', winsound.SND_FILENAME | winsound.SND_SYNC)\"",
            "shell": "powershell"
          },
          {
            "type": "agent",
            "prompt": "You are ריוי (Revi), the code quality guardian. Run: git diff HEAD --stat to see what changed. Sum the changed lines across source files (.ts, .tsx, .js, .jsx, .py, .css only — ignore .md, .json, settings, config files). If total changed source lines < 30, output nothing silently and stop immediately. Otherwise run /code-review for bugs, correctness issues, and things that can be simplified. Report findings concisely in Hebrew.",
            "timeout": 120,
            "statusMessage": "ריוי בודק את הקוד..."
          },
          {
            "type": "command",
            "command": "if (Test-Path 'deletions') { Get-ChildItem 'deletions' | Where-Object { $_.LastWriteTime -lt (Get-Date).AddDays(-14) } | Remove-Item -Force }; exit 0",
            "shell": "powershell"
          },
          {
            "type": "agent",
            "prompt": "Run 'git diff --cached' or 'git diff' to see staged/unstaged changes. If there are code changes, generate a concise and clean Git Commit message according to Conventional Commits rules. Write it in English.",
            "timeout": 60,
            "statusMessage": "מנסח הודעת קומיט מומלצת..."
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "Write-Output '{\"systemMessage\": \"Before compacting: note any open TODOs, architectural decisions, and lessons learned that should be saved to CLAUDE.md or rules/ before context is lost.\"}'",
            "shell": "powershell"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$json = [System.Console]::In.ReadToEnd() | ConvertFrom-Json; if ($json.tool_input.command -match 'rm -rf|reset --hard|drop table') { Write-Output '{\"continue\":false,\"stopReason\":\"BLOCKED: destructive command\"}'; exit 1 }",
            "shell": "powershell"
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "$j = [System.Console]::In.ReadToEnd() | ConvertFrom-Json; $f = $j.tool_input.file_path; if ($f -and (Test-Path $f -PathType Leaf)) { $d = Join-Path $PWD 'deletions'; New-Item -ItemType Directory -Force $d | Out-Null; $ts = Get-Date -Format 'yyyyMMdd_HHmmss'; $n = [IO.Path]::GetFileName($f); Copy-Item $f (Join-Path $d \"${ts}_$n\") -Force }; exit 0",
            "shell": "powershell",
            "statusMessage": "Backing up file before overwrite..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$j = [System.Console]::In.ReadToEnd() | ConvertFrom-Json; $cmd = $j.tool_input.command; if ($cmd -match '\\brm\\b|\\bRemove-Item\\b') { $parts = $cmd -split '\\s+' | Where-Object { $_ -notmatch '^-' -and $_ -notin @('rm','Remove-Item','') }; foreach ($f in $parts) { if ($f -and (Test-Path $f -PathType Leaf)) { $d = Join-Path $PWD 'deletions'; New-Item -ItemType Directory -Force $d | Out-Null; $ts = Get-Date -Format 'yyyyMMdd_HHmmss'; $n = [IO.Path]::GetFileName($f); Copy-Item $f (Join-Path $d \"${ts}_$n\") -Force } } }; exit 0",
            "shell": "powershell",
            "statusMessage": "Backing up files before deletion..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit",
        "hooks": [
          {
            "type": "command",
            "command": "$j = [System.Console]::In.ReadToEnd() | ConvertFrom-Json; $f = $j.tool_input.file_path; if ($f -notmatch '\\.(ts|tsx)$' -or -not (Test-Path 'tsconfig.json')) { exit 0 }; $r = npx tsc --noEmit 2>&1; if ($LASTEXITCODE -ne 0) { $lines = ($r | Select-Object -First 5) -join ' | '; $out = @{systemMessage = ('⚠️ TypeScript: ' + $lines)} | ConvertTo-Json -Compress; Write-Output $out }; exit 0",
            "shell": "powershell",
            "statusMessage": "בודק TypeScript..."
          }
        ]
      },
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "$j = [System.Console]::In.ReadToEnd() | ConvertFrom-Json; $f = $j.tool_input.file_path; if ($f -notmatch '\\.(ts|tsx)$' -or -not (Test-Path 'tsconfig.json')) { exit 0 }; $r = npx tsc --noEmit 2>&1; if ($LASTEXITCODE -ne 0) { $lines = ($r | Select-Object -First 5) -join ' | '; $out = @{systemMessage = ('⚠️ TypeScript: ' + $lines)} | ConvertTo-Json -Compress; Write-Output $out }; exit 0",
            "shell": "powershell",
            "statusMessage": "בודק TypeScript..."
          }
        ]
      }
    ]
  },
  "fileCheckpointingEnabled": true
}
