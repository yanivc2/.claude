<svg xmlns="http://www.w3.org/2000/svg"
     width="221cm" height="251cm"
     viewBox="0 0 2210 2510">

  <!-- Black background -->
  <rect width="2210" height="2510" fill="#000000"/>

  <!-- Large red circle -->
  <circle cx="1105" cy="1255" r="960" fill="#D40000"/>

  <!-- Subtle inner glow ring for depth -->
  <circle cx="1105" cy="1255" r="960" fill="none"
          stroke="#FF2222" stroke-width="18" opacity="0.4"/>

  <!-- "3" - very large yellow number -->
  <text x="1105" y="1080"
        text-anchor="middle"
        dominant-baseline="middle"
        font-family="'Arial Black', 'Franklin Gothic Heavy', Impact, sans-serif"
        font-size="820"
        font-weight="900"
        fill="#FFD000"
        letter-spacing="-10">3</text>

  <!-- Divider line between "3" and "24/7" -->
  <rect x="705" y="1360" width="800" height="22" rx="11" fill="#FFD000" opacity="0.85"/>

  <!-- "24/7" text -->
  <text x="1105" y="1590"
        text-anchor="middle"
        dominant-baseline="middle"
        font-family="'Arial Black', 'Franklin Gothic Heavy', Impact, sans-serif"
        font-size="370"
        font-weight="900"
        fill="#FFD000"
        letter-spacing="8">24/7</text>

</svg>
